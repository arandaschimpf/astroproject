---
interface Props {
	title: string;
}

const { title } = Astro.props;
---
<!doctype html>
	<html lang="en">
		<head>
			<meta charset="UTF-8" />
			<meta name="description" content="Astro description" />
			<meta name="viewport" content="width=device-width" />
			<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
			<title>{title}</title>
		</head>
		<body class="bg-zinc-200 flex flex-col items-center">
			<slot />
		</body>
	</html>

	<style is:global> /*estilo global */
		body {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  margin: 0;
  background-color: rgb(117, 94, 94);
 
  font-family: Arial, Helvetica, sans-serif;
}
.card{
  width: 300px;
  height: 300px;
  display: block;
  justify-content:center;
  align-items:center;
  background-color: rgb(103, 138, 168);
  border-radius: 20%;
}

.timer {
  width: 100px;
  height: 50px;
  border: 3px solid #000000;
  border-radius: 50%;
  padding: 5rem;
  margin: 10px 20%;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: rgb(243, 244, 247); 

}
.start-button{	
	/*margin: 40px 0 0 90px;*/
	margin: 0 30px;
	padding:10px ;
	border-radius: 25%;
	border-color: black;
	width: 4rem;
  	height: 3rem;
	background-color:rgb(208, 210, 216); 
}
.stop-button{
	padding:10px ;
	/*margin: 40px 0 0 90px;*/
	border-radius: 25%;
	border-color: black;
	width: 4rem;
  	height: 3rem;
	background-color:rgb(208, 210, 216); 
}
.division{
	justify-content: space-around;
	display: flex;
	padding: 30px 20px 0 0;

}
.start-button:active{
	background-color: rgb(103, 138, 168);
}
	</style>